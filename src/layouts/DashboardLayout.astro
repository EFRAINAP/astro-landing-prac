---
// 🏗️ Layout principal para el sistema de gestión
export interface Props {
  title: string;
  currentPage?: string;
  description?: string;
}

const { title, currentPage = '', description = 'Sistema de Gestión Integral' } = Astro.props;

import Layout from './Layout.astro';
import Sidebar from '../modules/sistema/components/Sidebar.svelte';
import { getMenuItems } from '../modules/sistema/services/dataService';
import Icon from '../components/ui/Icon.svelte';

const menuItems = await getMenuItems();
---

<Layout title={`${title} - Sistema SIG`} description={description}>
  <!-- ESTRUCTURA FIJA: Sidebar + Área Principal -->
  <div class="min-h-screen bg-gray-100">
    
    <!-- SIDEBAR FIJO (Ocupa toda la altura) -->
    <Sidebar 
      menuItems={menuItems}
      currentPath={Astro.url.pathname}
      client:load
    />
    
    <!-- Área Principal (Header + Contenido + Footer) -->
    <div class="ml-64 flex flex-col min-h-screen transition-all duration-300" data-main-content id="main-content">
      
      <!-- HEADER FIJO -->
      <header class="bg-white shadow-sm border-b border-gray-200 flex-shrink-0 sticky top-0 z-10">
        <div class="px-6 lg:px-8">
          <div class="flex justify-between items-center py-4 h-16">
            <div class="flex items-center space-x-4">
              <!-- Botón único para contraer/expandir sidebar -->
              <button id="toggleSidebar" 
                      class="p-2 rounded-lg text-gray-400 hover:text-gray-500 hover:bg-gray-100 
                             focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 
                             transition-colors" 
                      title="Contraer/Expandir sidebar">
                <!-- Icono fijo (no cambia) -->
                <Icon name="menu" size="sm" variant='primary' />
              </button>
            </div>
            <!-- Título de la página -->
            <div class="flex items-center">
              <h1 class="text-2xl font-bold text-gray-900">{title}</h1>
              {description && (
                <span class="ml-4 text-sm text-gray-500 hidden md:block">— {description}</span>
              )}
            </div>
            
            <!-- Acciones del header -->
            <div class="flex items-center space-x-4">
              <!-- Búsqueda rápida -->
              <div class="relative hidden md:block">
                <input
                  type="text"
                  placeholder="Buscar..."
                  class="w-64 pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                />
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                  <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                </div>
              </div>
              
              <!-- Notificaciones -->
              <button class="relative p-2 rounded-lg text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5zM9 7h6a2 2 0 012 2v8a2 2 0 01-2 2H7a2 2 0 01-2-2V9a2 2 0 012-2z" />
                </svg>
                <span class="absolute -top-1 -right-1 block h-4 w-4 rounded-full bg-red-500 text-white text-xs flex items-center justify-center font-bold">3</span>
              </button>
              
              <!-- Avatar del usuario -->
              <div class="relative">
                <button class="flex items-center space-x-3 text-sm rounded-lg p-2 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                  <img class="h-8 w-8 rounded-full border-2 border-gray-200 shadow-sm" src="/api/placeholder/32/32" alt="Usuario" />
                  <div class="hidden lg:block text-left">
                    <p class="font-medium text-gray-900">Admin Usuario</p>
                    <p class="text-xs text-gray-500">Administrador</p>
                  </div>
                  <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </header>
      
      <!-- CONTENIDO EXPANDIBLE (flex-1) -->
      <main class="flex-1 overflow-y-auto bg-gray-50 focus:outline-none">
        <div class="py-8">
          <div class="mx-auto px-6 lg:px-8">
            <slot />
          </div>
        </div>
      </main>

      <!-- FOOTER FIJO -->
      <footer class="bg-white border-t border-gray-200 flex-shrink-0 h-16 sticky bottom-0 z-10">
        <div class="px-6 lg:px-8 py-4">
          <div class="flex items-center justify-between">
            <!-- Información del sistema -->
            <div class="flex items-center space-x-6 text-sm text-gray-500">
              <div class="flex items-center">
                <div class="w-2 h-2 bg-green-400 rounded-full mr-2 animate-pulse"></div>
                <span>Sistema Activo</span>
              </div>
              <span>Versión 2.5.1</span>
              <span>Producción</span>
            </div>
            
            <!-- Enlaces del footer -->
            <div class="flex items-center space-x-6 text-sm">
              <button class="text-gray-500 hover:text-gray-700 transition-colors">
                Soporte
              </button>
              <button class="text-gray-500 hover:text-gray-700 transition-colors">
                Documentación
              </button>
              <button class="text-gray-500 hover:text-gray-700 transition-colors">
                API Status
              </button>
            </div>
          </div>
        </div>
      </footer>
      
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleButton = document.getElementById('toggleSidebar');
    toggleButton?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('toggleSidebar'));
    });
  });
</script>

<style>
  /* CSS simple que funciona */
  [data-main-content] {
    margin-left: 16rem; /* 256px por defecto */
    transition: margin-left 0.3s ease;
  }
  
  /* Scrollbar */
  main::-webkit-scrollbar {
    width: 8px;
  }

  main::-webkit-scrollbar-track {
    background: #f1f5f9;
  }

  main::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 4px;
  }
</style>