---
// 🏗️ Layout principal para el sistema de gestión
export interface Props {
  title: string;
  currentPage?: string;
  description?: string;
}

const { title, currentPage = '', description = 'Sistema de Gestión Integral' } = Astro.props;

import Layout from './Layout.astro';
import Sidebar from '../modules/sistema/components/Sidebar.svelte';
import { getMenuItems } from '../modules/sistema/services/dataService';

const menuItems = await getMenuItems();
---

<Layout title={`${title} - Sistema SIG`} description={description}>
  <div class="flex min-h-screen bg-gray-100">
    <!-- Sidebar -->
    <Sidebar 
      menuItems={menuItems}
      currentPath={Astro.url.pathname}
      client:load
    />
    
    <!-- Contenido principal -->
    <div class="flex-1 lg:pl-64">
      <!-- Header de la página -->
      <header class="bg-white shadow-sm border-b border-gray-200 lg:ml-0">
        <div class="px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center py-6 md:justify-start md:space-x-10">
            <!-- Título de la página -->
            <div class="flex justify-start lg:w-0 lg:flex-1">
              <h1 class="text-2xl font-bold text-gray-900">{title}</h1>
            </div>
            
            <!-- Acciones del header -->
            <div class="hidden md:flex items-center justify-end md:flex-1 lg:w-0">
              <div class="flex items-center space-x-4">
                <!-- Notificaciones -->
                <button class="relative p-1 rounded-full text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                  <span class="sr-only">Ver notificaciones</span>
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5V17zM9 7h6a2 2 0 012 2v8a2 2 0 01-2 2H7a2 2 0 01-2-2V9a2 2 0 012-2z" />
                  </svg>
                  <span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-red-400 ring-2 ring-white"></span>
                </button>
                
                <!-- Avatar del usuario -->
                <div class="relative">
                  <button class="flex items-center text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    <span class="sr-only">Abrir menú de usuario</span>
                    <img class="h-8 w-8 rounded-full" src="/api/placeholder/32/32" alt="Usuario" />
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>
      
      <!-- Contenido de la página -->
      <main class="flex-1 relative overflow-y-auto focus:outline-none">
        <div class="py-6">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <slot />
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>

<style>
  /* Estilos adicionales para el layout del sistema */
  main {
    min-height: calc(100vh - 80px);
  }
  
  /* Mejoras en el scroll */
  main::-webkit-scrollbar {
    width: 6px;
  }
  
  main::-webkit-scrollbar-track {
    background: #f1f1f1;
  }
  
  main::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 3px;
  }
  
  main::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
  }
</style>