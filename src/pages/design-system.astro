---
// 🎨 EJEMPLO DE USO DEL SISTEMA DE DISEÑO
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Button from "../components/ui/Button.svelte";
import Card from "../components/ui/Card.svelte";
---

<Layout title="Sistema de Diseño - Demo" description="Demostración del sistema de diseño centralizado">
	<Header currentPage="design-system" />
	
	<!-- Hero -->
	<section class="bg-gradient-to-br from-purple-50 to-blue-50 pt-20 pb-16">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
					🎨 Sistema de Diseño
					<span class="gradient-text block">Centralizado</span>
				</h1>
				<p class="text-xl text-gray-600 mb-8">
					Todos los estilos y componentes en un lugar para mantener consistencia
				</p>
			</div>
		</div>
	</section>

	<!-- Buttons Demo -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold text-gray-900 mb-8">🔘 Botones</h2>
			
			<div class="space-y-8">
				<!-- Botones sólidos -->
				<div>
					<h3 class="text-lg font-semibold text-gray-700 mb-4">Sólidos</h3>
					<div class="flex flex-wrap gap-4">
						<Button variant="primary">Primario</Button>
						<Button variant="secondary">Secundario</Button>
						<Button variant="success">Éxito</Button>
						<Button variant="warning">Advertencia</Button>
					</div>
				</div>

				<!-- Botones outline -->
				<div>
					<h3 class="text-lg font-semibold text-gray-700 mb-4">Outline</h3>
					<div class="flex flex-wrap gap-4">
						<Button variant="primary" outline={true}>Primario</Button>
						<Button variant="secondary" outline={true}>Secundario</Button>
						<Button variant="success" outline={true}>Éxito</Button>
						<Button variant="warning" outline={true}>Advertencia</Button>
					</div>
				</div>

				<!-- Tamaños -->
				<div>
					<h3 class="text-lg font-semibold text-gray-700 mb-4">Tamaños</h3>
					<div class="flex items-end flex-wrap gap-4">
						<Button variant="primary" size="sm">Pequeño</Button>
						<Button variant="primary" size="md">Mediano</Button>
						<Button variant="primary" size="lg">Grande</Button>
					</div>
				</div>

				<!-- Estados -->
				<div>
					<h3 class="text-lg font-semibold text-gray-700 mb-4">Estados</h3>
					<div class="flex flex-wrap gap-4">
						<Button variant="primary">Normal</Button>
						<Button variant="primary" loading={true}>Cargando</Button>
						<Button variant="primary" disabled={true}>Deshabilitado</Button>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Cards Demo -->
	<section class="py-16 bg-gray-50">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold text-gray-900 mb-8">📋 Cards</h2>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<Card 
					variant="primary"
					icon="🚀"
					title="Card Primaria"
					description="Esta card usa el tema primario centralizado del sistema de diseño."
				/>
				<Card 
					variant="secondary"
					icon="⚙️"
					title="Card Secundaria"
					description="Card con tema secundario, todos los estilos vienen del theme.ts."
				/>
				<Card 
					variant="success"
					icon="✅"
					title="Card de Éxito"
					description="Tema verde para indicar estados exitosos o positivos."
				/>
				<Card 
					variant="warning"
					icon="⚠️"
					title="Card de Advertencia"
					description="Tema amarillo para alertas o información importante."
				/>
			</div>
		</div>
	</section>

	<!-- Code Examples -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold text-gray-900 mb-8">📝 Cómo Usar</h2>
			
			<div class="space-y-8">
				<!-- Importar -->
				<div class="bg-gray-900 rounded-lg p-6">
					<h3 class="text-white font-semibold mb-3">1. Importar en tu componente</h3>
					<pre class="text-green-400 text-sm overflow-x-auto"><code>import Button from '../ui/Button.svelte';
import &#123; getButtonClasses, animations &#125; from '../lib/theme';
import &#123; cn, formatPrice &#125; from '../lib/utils';</code></pre>
				</div>

				<!-- Usar -->
				<div class="bg-gray-900 rounded-lg p-6">
					<h3 class="text-white font-semibold mb-3">2. Usar en tu template</h3>
					<pre class="text-blue-400 text-sm overflow-x-auto"><code>&lt;Button variant="primary" size="lg" outline=&#123;true&#125;&gt;
  ¡Cotiza Ahora!
&lt;/Button&gt;

&lt;Card 
  variant="success"
  icon="💰"
  title="Precio: &#123;formatPrice(1500)&#125;"
  description="Card con precio formateado"
/&gt;</code></pre>
				</div>

				<!-- Estilos manuales -->
				<div class="bg-gray-900 rounded-lg p-6">
					<h3 class="text-white font-semibold mb-3">3. Clases manuales con helper functions</h3>
					<pre class="text-yellow-400 text-sm overflow-x-auto"><code>const buttonClass = getButtonClasses('primary', true); // outline button
const cardClass = getCardClasses('success', true);     // animated card
const combinedClass = cn(buttonClass, 'mt-4', isActive && 'ring-2');</code></pre>
				</div>
			</div>
		</div>
	</section>

	<!-- Benefits -->
	<section class="py-16 bg-blue-50">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold text-gray-900 mb-8">✨ Beneficios</h2>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<div class="text-center">
					<div class="text-4xl mb-4">🎯</div>
					<h3 class="font-semibold text-gray-800 mb-2">Consistencia</h3>
					<p class="text-gray-600 text-sm">Todos los componentes usan los mismos colores y estilos</p>
				</div>
				<div class="text-center">
					<div class="text-4xl mb-4">🚀</div>
					<h3 class="font-semibold text-gray-800 mb-2">Productividad</h3>
					<p class="text-gray-600 text-sm">No reinventes la rueda, usa funciones ya creadas</p>
				</div>
				<div class="text-center">
					<div class="text-4xl mb-4">🔧</div>
					<h3 class="font-semibold text-gray-800 mb-2">Mantenimiento</h3>
					<p class="text-gray-600 text-sm">Cambia un color en theme.ts y se aplica en toda la app</p>
				</div>
			</div>
		</div>
	</section>

	<Footer />
</Layout>