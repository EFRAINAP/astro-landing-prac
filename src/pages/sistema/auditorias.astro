---
// 🔍 Página de gestión de auditorías
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getAuditorias, getDashboardStats } from '../../modules/sistema';

const auditorias = await getAuditorias();
const stats = await getDashboardStats();
---

<DashboardLayout title="Auditorías" currentPage="auditorias">
  <!-- Panel de control de auditorías -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="h-10 w-10 bg-blue-500 rounded-lg flex items-center justify-center">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Planificadas</dt>
              <dd class="text-lg font-medium text-gray-900">{auditorias.filter(a => a.estado === 'planificada').length}</dd>
            </dl>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="h-10 w-10 bg-yellow-500 rounded-lg flex items-center justify-center">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">En Curso</dt>
              <dd class="text-lg font-medium text-gray-900">{auditorias.filter(a => a.estado === 'enCurso').length}</dd>
            </dl>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="h-10 w-10 bg-green-500 rounded-lg flex items-center justify-center">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Completadas</dt>
              <dd class="text-lg font-medium text-gray-900">{auditorias.filter(a => a.estado === 'terminada' || a.estado === 'reportada').length}</dd>
            </dl>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="h-10 w-10 bg-purple-500 rounded-lg flex items-center justify-center">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
              </svg>
            </div>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Total Auditorías</dt>
              <dd class="text-lg font-medium text-gray-900">{auditorias.length}</dd>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Calendario de auditorías -->
  <div class="bg-white shadow rounded-lg mb-8 overflow-hidden">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Calendario de Auditorías</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Próximas auditorías programadas</p>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {auditorias.map((auditoria) => (
          <div class={`border-l-4 bg-white p-4 rounded-lg shadow-sm ${
            auditoria.estado === 'planificada' ? 'border-blue-500' :
            auditoria.estado === 'enCurso' ? 'border-yellow-500' :
            auditoria.estado === 'terminada' ? 'border-green-500' :
            'border-gray-500'
          }`}>
            <div class="flex items-center justify-between mb-2">
              <h4 class="text-sm font-medium text-gray-900 truncate">{auditoria.nombre}</h4>
              <span class={`inline-flex px-2 py-1 text-xs font-medium rounded-full ${
                auditoria.estado === 'planificada' ? 'bg-blue-100 text-blue-800' :
                auditoria.estado === 'enCurso' ? 'bg-yellow-100 text-yellow-800' :
                auditoria.estado === 'terminada' ? 'bg-green-100 text-green-800' :
                'bg-gray-100 text-gray-800'
              }`}>
                {auditoria.estado === 'enCurso' ? 'En Curso' : 
                 auditoria.estado === 'planificada' ? 'Planificada' : 
                 auditoria.estado === 'terminada' ? 'Terminada' : 'Reportada'}
              </span>
            </div>
            <p class="text-sm text-gray-600 mb-2">{auditoria.codigo}</p>
            <div class="space-y-1 text-xs text-gray-500">
              <div>Norma: {auditoria.norma}</div>
              <div>Auditor Líder: {auditoria.auditorLider}</div>
              <div>Fecha: {auditoria.fechaInicio.toLocaleDateString('es-ES')} - {auditoria.fechaFin.toLocaleDateString('es-ES')}</div>
            </div>
            <div class="mt-3 flex justify-end">
              <button class="text-blue-600 hover:text-blue-900 text-xs font-medium">Ver detalles</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Tabla detallada de auditorías -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg leading-6 font-medium text-gray-900">Gestión de Auditorías</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500">Control y seguimiento del programa de auditorías</p>
        </div>
        <div class="flex space-x-3">
          <button class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors">
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Programa Anual
          </button>
          <button class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors">
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Nueva Auditoría
          </button>
        </div>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Código
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Auditoría
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Tipo
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Estado
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Auditor Líder
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Fechas
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Hallazgos
            </th>
            <th scope="col" class="relative px-6 py-3">
              <span class="sr-only">Acciones</span>
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          {auditorias.map((auditoria) => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                {auditoria.codigo}
              </td>
              <td class="px-6 py-4">
                <div>
                  <div class="text-sm font-medium text-gray-900">{auditoria.nombre}</div>
                  <div class="text-sm text-gray-500">Norma: {auditoria.norma}</div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class={`inline-flex px-2 py-1 text-xs font-medium rounded-full ${
                  auditoria.tipo === 'interna' ? 'bg-blue-100 text-blue-800' :
                  auditoria.tipo === 'externa' ? 'bg-purple-100 text-purple-800' :
                  'bg-green-100 text-green-800'
                }`}>
                  {auditoria.tipo}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class={`inline-flex px-2 py-1 text-xs font-medium rounded-full ${
                  auditoria.estado === 'planificada' ? 'bg-blue-100 text-blue-800' :
                  auditoria.estado === 'enCurso' ? 'bg-yellow-100 text-yellow-800' :
                  auditoria.estado === 'terminada' ? 'bg-green-100 text-green-800' :
                  'bg-gray-100 text-gray-800'
                }`}>
                  {auditoria.estado === 'enCurso' ? 'En Curso' : 
                   auditoria.estado === 'planificada' ? 'Planificada' : 
                   auditoria.estado === 'terminada' ? 'Terminada' : 'Reportada'}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <div>{auditoria.auditorLider}</div>
                <div class="text-xs text-gray-500">
                  + {auditoria.auditores.length} auditores
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <div>{auditoria.fechaInicio.toLocaleDateString('es-ES')}</div>
                <div>{auditoria.fechaFin.toLocaleDateString('es-ES')}</div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <div class="flex space-x-2">
                  <span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded-full text-xs">
                    {auditoria.hallazgos || 0} hallazgos
                  </span>
                  {(auditoria.noConformidades || 0) > 0 && (
                    <span class="bg-red-100 text-red-800 px-2 py-1 rounded-full text-xs">
                      {auditoria.noConformidades} NC
                    </span>
                  )}
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <button class="text-blue-600 hover:text-blue-900 mr-3">Ver</button>
                <button class="text-indigo-600 hover:text-indigo-900 mr-3">Editar</button>
                <button class="text-green-600 hover:text-green-900">Reporte</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>