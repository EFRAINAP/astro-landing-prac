---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
---

<Layout title="Cotiza tu Proyecto - Mi Landing" description="Solicita una cotización personalizada para tu proyecto web o aplicación móvil">
	<Header currentPage="cotiza" />
	
	<!-- Hero Section -->
	<section class="bg-gradient-to-br from-blue-50 via-white to-purple-50 pt-20 pb-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
					Cotiza Tu
					<span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
						Proyecto
					</span>
				</h1>
				<p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
					Completa el formulario y recibe una propuesta personalizada en menos de 24 horas
				</p>
			</div>
		</div>
	</section>

	<!-- Quote Form -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<form id="quote-form" class="space-y-8">
				<!-- Project Type -->
				<div class="bg-gray-50 rounded-lg p-8">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">¿Qué tipo de proyecto necesitas?</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
						<label class="cursor-pointer">
							<input type="radio" name="project_type" value="website" class="sr-only peer">
							<div class="border-2 border-gray-200 rounded-lg p-6 text-center hover:border-blue-500 peer-checked:border-blue-500 peer-checked:bg-blue-50 transition-all">
								<div class="text-4xl mb-3">💻</div>
								<h3 class="font-semibold text-gray-900">Sitio Web</h3>
								<p class="text-sm text-gray-600">Landing pages, corporativos, blogs</p>
							</div>
						</label>
						<label class="cursor-pointer">
							<input type="radio" name="project_type" value="ecommerce" class="sr-only peer">
							<div class="border-2 border-gray-200 rounded-lg p-6 text-center hover:border-green-500 peer-checked:border-green-500 peer-checked:bg-green-50 transition-all">
								<div class="text-4xl mb-3">🛒</div>
								<h3 class="font-semibold text-gray-900">E-commerce</h3>
								<p class="text-sm text-gray-600">Tiendas online, marketplaces</p>
							</div>
						</label>
						<label class="cursor-pointer">
							<input type="radio" name="project_type" value="mobile" class="sr-only peer">
							<div class="border-2 border-gray-200 rounded-lg p-6 text-center hover:border-purple-500 peer-checked:border-purple-500 peer-checked:bg-purple-50 transition-all">
								<div class="text-4xl mb-3">📱</div>
								<h3 class="font-semibold text-gray-900">App Móvil</h3>
								<p class="text-sm text-gray-600">iOS, Android, PWAs</p>
							</div>
						</label>
					</div>
				</div>

				<!-- Budget -->
				<div class="bg-gray-50 rounded-lg p-8">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">¿Cuál es tu presupuesto aproximado?</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
						<label class="cursor-pointer">
							<input type="radio" name="budget" value="1000-3000" class="sr-only peer">
							<div class="border-2 border-gray-200 rounded-lg p-6 hover:border-blue-500 peer-checked:border-blue-500 peer-checked:bg-blue-50 transition-all">
								<h3 class="font-semibold text-gray-900">$1,000 - $3,000</h3>
								<p class="text-sm text-gray-600">Proyectos básicos y landing pages</p>
							</div>
						</label>
						<label class="cursor-pointer">
							<input type="radio" name="budget" value="3000-7000" class="sr-only peer">
							<div class="border-2 border-gray-200 rounded-lg p-6 hover:border-blue-500 peer-checked:border-blue-500 peer-checked:bg-blue-50 transition-all">
								<h3 class="font-semibold text-gray-900">$3,000 - $7,000</h3>
								<p class="text-sm text-gray-600">Sitios web completos y e-commerce básico</p>
							</div>
						</label>
						<label class="cursor-pointer">
							<input type="radio" name="budget" value="7000-15000" class="sr-only peer">
							<div class="border-2 border-gray-200 rounded-lg p-6 hover:border-blue-500 peer-checked:border-blue-500 peer-checked:bg-blue-50 transition-all">
								<h3 class="font-semibold text-gray-900">$7,000 - $15,000</h3>
								<p class="text-sm text-gray-600">E-commerce avanzado y aplicaciones</p>
							</div>
						</label>
						<label class="cursor-pointer">
							<input type="radio" name="budget" value="15000+" class="sr-only peer">
							<div class="border-2 border-gray-200 rounded-lg p-6 hover:border-blue-500 peer-checked:border-blue-500 peer-checked:bg-blue-50 transition-all">
								<h3 class="font-semibold text-gray-900">$15,000+</h3>
								<p class="text-sm text-gray-600">Proyectos empresariales complejos</p>
							</div>
						</label>
					</div>
				</div>

				<!-- Features -->
				<div class="bg-gray-50 rounded-lg p-8">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">¿Qué funcionalidades necesitas?</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
						<label class="flex items-center space-x-3 cursor-pointer">
							<input type="checkbox" name="features" value="responsive_design" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
							<span class="text-gray-700">Diseño Responsive</span>
						</label>
						<label class="flex items-center space-x-3 cursor-pointer">
							<input type="checkbox" name="features" value="cms" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
							<span class="text-gray-700">Sistema de Gestión (CMS)</span>
						</label>
						<label class="flex items-center space-x-3 cursor-pointer">
							<input type="checkbox" name="features" value="ecommerce" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
							<span class="text-gray-700">Tienda Online</span>
						</label>
						<label class="flex items-center space-x-3 cursor-pointer">
							<input type="checkbox" name="features" value="blog" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
							<span class="text-gray-700">Blog/Noticias</span>
						</label>
						<label class="flex items-center space-x-3 cursor-pointer">
							<input type="checkbox" name="features" value="user_registration" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
							<span class="text-gray-700">Registro de Usuarios</span>
						</label>
						<label class="flex items-center space-x-3 cursor-pointer">
							<input type="checkbox" name="features" value="payment_gateway" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
							<span class="text-gray-700">Pasarela de Pagos</span>
						</label>
						<label class="flex items-center space-x-3 cursor-pointer">
							<input type="checkbox" name="features" value="api_integration" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
							<span class="text-gray-700">Integración con APIs</span>
						</label>
						<label class="flex items-center space-x-3 cursor-pointer">
							<input type="checkbox" name="features" value="analytics" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
							<span class="text-gray-700">Analytics y Reportes</span>
						</label>
					</div>
				</div>

				<!-- Contact Information -->
				<div class="bg-gray-50 rounded-lg p-8">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">Información de Contacto</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div>
							<label for="name" class="block text-sm font-medium text-gray-700 mb-2">Nombre Completo *</label>
							<input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
						</div>
						<div>
							<label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email *</label>
							<input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
						</div>
						<div>
							<label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Teléfono</label>
							<input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
						</div>
						<div>
							<label for="company" class="block text-sm font-medium text-gray-700 mb-2">Empresa</label>
							<input type="text" id="company" name="company" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
						</div>
					</div>
				</div>

				<!-- Project Details -->
				<div class="bg-gray-50 rounded-lg p-8">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">Detalles del Proyecto</h2>
					<div class="space-y-6">
						<div>
							<label for="project_description" class="block text-sm font-medium text-gray-700 mb-2">Descripción del Proyecto *</label>
							<textarea id="project_description" name="project_description" rows="4" required 
								class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
								placeholder="Cuéntanos sobre tu proyecto, objetivos, audiencia target, etc."></textarea>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div>
								<label for="timeline" class="block text-sm font-medium text-gray-700 mb-2">Timeline Deseado</label>
								<select id="timeline" name="timeline" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
									<option value="">Seleccionar...</option>
									<option value="asap">Lo antes posible</option>
									<option value="1-month">1 mes</option>
									<option value="2-3-months">2-3 meses</option>
									<option value="3-6-months">3-6 meses</option>
									<option value="6-months-plus">Más de 6 meses</option>
								</select>
							</div>
							<div>
								<label for="current_website" class="block text-sm font-medium text-gray-700 mb-2">¿Tienes sitio web actual?</label>
								<input type="url" id="current_website" name="current_website" 
									class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
									placeholder="https://ejemplo.com">
							</div>
						</div>
					</div>
				</div>

				<!-- Submit Button -->
				<div class="text-center">
					<button type="submit" id="submit-btn"
						class="bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-semibold px-12 py-4 rounded-lg text-lg transition-all duration-300 hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed">
						<span id="submit-text">Enviar Cotización 🚀</span>
						<span id="loading-text" class="hidden">Enviando...</span>
					</button>
					<p class="text-gray-600 text-sm mt-4">Te responderemos en menos de 24 horas</p>
				</div>

				<!-- Success Message -->
				<div id="success-message" class="hidden bg-green-50 border border-green-200 rounded-lg p-6 text-center">
					<div class="text-green-600 text-4xl mb-3">✅</div>
					<h3 class="text-xl font-semibold text-green-800 mb-2">¡Cotización Enviada!</h3>
					<p class="text-green-700">Gracias por tu interés. Nos pondremos en contacto contigo pronto.</p>
				</div>
			</form>
		</div>
	</section>

	<!-- Why Choose Us -->
	<section class="py-20 bg-blue-600">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-white mb-4">¿Por qué cotizar con nosotros?</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="text-center text-white">
					<div class="text-4xl mb-4">⚡</div>
					<h3 class="text-xl font-semibold mb-2">Respuesta Rápida</h3>
					<p class="text-blue-100">Recibes tu cotización en menos de 24 horas</p>
				</div>
				<div class="text-center text-white">
					<div class="text-4xl mb-4">💰</div>
					<h3 class="text-xl font-semibold mb-2">Sin Compromisos</h3>
					<p class="text-blue-100">Cotización gratuita y sin obligaciones</p>
				</div>
				<div class="text-center text-white">
					<div class="text-4xl mb-4">🎯</div>
					<h3 class="text-xl font-semibold mb-2">Personalizada</h3>
					<p class="text-blue-100">Propuesta adaptada a tus necesidades específicas</p>
				</div>
			</div>
		</div>
	</section>

	<Footer />

	<script>
		// Handle form submission
		const quoteFormEl = document.getElementById('quote-form');
		if (quoteFormEl) {
			quoteFormEl.addEventListener('submit', async function(e) {
				e.preventDefault();
				
				const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
				const submitText = document.getElementById('submit-text');
				const loadingText = document.getElementById('loading-text');
				const successMessage = document.getElementById('success-message');
				
				// Show loading state
				if (submitBtn) submitBtn.disabled = true;
				if (submitText) submitText.classList.add('hidden');
				if (loadingText) loadingText.classList.remove('hidden');
				
				// Simulate form submission (replace with actual API call)
				setTimeout(() => {
					// Hide form and show success message
					const formEl = document.getElementById('quote-form') as HTMLElement;
					if (formEl) formEl.style.display = 'none';
					if (successMessage) {
						successMessage.classList.remove('hidden');
						// Scroll to success message
						successMessage.scrollIntoView({ behavior: 'smooth' });
					}
				}, 2000);
			});
		}

		// Add interactivity to radio buttons
		document.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((radio) => {
			radio.addEventListener('change', function() {
				// Remove previous selections from the same group
				const groupName = radio.getAttribute('name');
				if (groupName) {
					document.querySelectorAll<HTMLInputElement>(`input[name="${groupName}"]`).forEach((r) => {
						const labelEl = r.closest('label');
						const divEl = labelEl?.querySelector('div');
						if (divEl) {
							divEl.classList.remove('border-blue-500', 'border-green-500', 'border-purple-500', 'bg-blue-50', 'bg-green-50', 'bg-purple-50');
						}
					});
				}
				
				// Add selection styling to current choice
				const labelEl = radio.closest('label');
				const container = labelEl?.querySelector('div');
				if (container) {
					if (radio.value === 'website' || groupName === 'budget') {
						container.classList.add('border-blue-500', 'bg-blue-50');
					} else if (radio.value === 'ecommerce') {
						container.classList.add('border-green-500', 'bg-green-50');
					} else if (radio.value === 'mobile') {
						container.classList.add('border-purple-500', 'bg-purple-50');
					}
				}
			});
		});
	</script>
</Layout>