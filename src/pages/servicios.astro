---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
---

<Layout title="Servicios - Mi Landing" description="Descubre nuestros servicios de desarrollo web, aplicaciones móviles y soluciones digitales">
	<Header currentPage="servicios" />
	
	<!-- Hero Section -->
	<section class="bg-gradient-to-br from-blue-50 via-white to-purple-50 pt-20 pb-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
					Nuestros
					<span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
						Servicios
					</span>
				</h1>
				<p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
					Soluciones completas de desarrollo web y móvil adaptadas a tus necesidades específicas
				</p>
			</div>
		</div>
	</section>

	<!-- Main Services -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
				<!-- Web Development -->
				<div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-8 hover:shadow-xl transition-all duration-300">
					<div class="text-5xl text-blue-600 mb-6">💻</div>
					<h3 class="text-2xl font-bold text-gray-900 mb-4">Desarrollo Web</h3>
					<p class="text-gray-600 mb-6">
						Creamos sitios web modernos, rápidos y optimizados que convierten visitantes en clientes.
					</p>
					
					<div class="space-y-4">
						<h4 class="font-semibold text-gray-900">Incluye:</h4>
						<ul class="space-y-2 text-gray-600">
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Diseño Responsive
							</li>
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								SEO Optimizado
							</li>
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Velocidad de carga optimizada
							</li>
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Panel de administración
							</li>
						</ul>
					</div>
					
					<div class="mt-8">
						<div class="text-2xl font-bold text-blue-600 mb-2">Desde $1,500</div>
						<a href="/cotiza" class="block w-full bg-blue-600 hover:bg-blue-700 text-white text-center py-3 rounded-lg font-semibold transition-colors">
							Cotizar Proyecto
						</a>
					</div>
				</div>

				<!-- E-commerce -->
				<div class="bg-gradient-to-br from-green-50 to-green-100 rounded-2xl p-8 hover:shadow-xl transition-all duration-300">
					<div class="text-5xl text-green-600 mb-6">🛒</div>
					<h3 class="text-2xl font-bold text-gray-900 mb-4">E-commerce</h3>
					<p class="text-gray-600 mb-6">
						Tiendas online completas con pasarelas de pago y gestión de inventario avanzada.
					</p>
					
					<div class="space-y-4">
						<h4 class="font-semibold text-gray-900">Incluye:</h4>
						<ul class="space-y-2 text-gray-600">
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Catálogo de productos
							</li>
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Carrito de compras
							</li>
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Pasarelas de pago
							</li>
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Gestión de inventario
							</li>
						</ul>
					</div>
					
					<div class="mt-8">
						<div class="text-2xl font-bold text-green-600 mb-2">Desde $3,000</div>
						<a href="/cotiza" class="block w-full bg-green-600 hover:bg-green-700 text-white text-center py-3 rounded-lg font-semibold transition-colors">
							Cotizar Proyecto
						</a>
					</div>
				</div>

				<!-- Mobile Apps -->
				<div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-2xl p-8 hover:shadow-xl transition-all duration-300">
					<div class="text-5xl text-purple-600 mb-6">📱</div>
					<h3 class="text-2xl font-bold text-gray-900 mb-4">Apps Móviles</h3>
					<p class="text-gray-600 mb-6">
						Aplicaciones nativas y PWAs para iOS y Android con excelente experiencia de usuario.
					</p>
					
					<div class="space-y-4">
						<h4 class="font-semibold text-gray-900">Incluye:</h4>
						<ul class="space-y-2 text-gray-600">
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Desarrollo iOS/Android
							</li>
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Diseño UX/UI nativo
							</li>
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								API Backend completa
							</li>
							<li class="flex items-center">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Publicación en stores
							</li>
						</ul>
					</div>
					
					<div class="mt-8">
						<div class="text-2xl font-bold text-purple-600 mb-2">Desde $5,000</div>
						<a href="/cotiza" class="block w-full bg-purple-600 hover:bg-purple-700 text-white text-center py-3 rounded-lg font-semibold transition-colors">
							Cotizar Proyecto
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Technologies -->
	<section class="py-20 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
					Tecnologías que Utilizamos
				</h2>
				<p class="text-xl text-gray-600">
					Stack tecnológico moderno para resultados excepcionales
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
				<!-- Frontend -->
				<div class="bg-white rounded-lg p-6 shadow-lg">
					<h3 class="text-lg font-semibold text-gray-900 mb-4">Frontend</h3>
					<div class="space-y-3">
						<div class="flex items-center">
							<span class="text-blue-500 mr-2">⚡</span>
							<span class="text-gray-700">Astro</span>
						</div>
						<div class="flex items-center">
							<span class="text-blue-500 mr-2">⚛️</span>
							<span class="text-gray-700">React</span>
						</div>
						<div class="flex items-center">
							<span class="text-orange-500 mr-2">🔥</span>
							<span class="text-gray-700">Svelte</span>
						</div>
						<div class="flex items-center">
							<span class="text-green-500 mr-2">💚</span>
							<span class="text-gray-700">Vue.js</span>
						</div>
					</div>
				</div>

				<!-- Backend -->
				<div class="bg-white rounded-lg p-6 shadow-lg">
					<h3 class="text-lg font-semibold text-gray-900 mb-4">Backend</h3>
					<div class="space-y-3">
						<div class="flex items-center">
							<span class="text-green-500 mr-2">🟢</span>
							<span class="text-gray-700">Node.js</span>
						</div>
						<div class="flex items-center">
							<span class="text-purple-500 mr-2">💜</span>
							<span class="text-gray-700">Express</span>
						</div>
						<div class="flex items-center">
							<span class="text-red-500 mr-2">🚀</span>
							<span class="text-gray-700">NestJS</span>
						</div>
						<div class="flex items-center">
							<span class="text-blue-500 mr-2">🔷</span>
							<span class="text-gray-700">TypeScript</span>
						</div>
					</div>
				</div>

				<!-- Database -->
				<div class="bg-white rounded-lg p-6 shadow-lg">
					<h3 class="text-lg font-semibold text-gray-900 mb-4">Base de Datos</h3>
					<div class="space-y-3">
						<div class="flex items-center">
							<span class="text-blue-500 mr-2">🐘</span>
							<span class="text-gray-700">PostgreSQL</span>
						</div>
						<div class="flex items-center">
							<span class="text-green-500 mr-2">🍃</span>
							<span class="text-gray-700">MongoDB</span>
						</div>
						<div class="flex items-center">
							<span class="text-orange-500 mr-2">🔥</span>
							<span class="text-gray-700">Firebase</span>
						</div>
						<div class="flex items-center">
							<span class="text-red-500 mr-2">📊</span>
							<span class="text-gray-700">Redis</span>
						</div>
					</div>
				</div>

				<!-- Tools -->
				<div class="bg-white rounded-lg p-6 shadow-lg">
					<h3 class="text-lg font-semibold text-gray-900 mb-4">Herramientas</h3>
					<div class="space-y-3">
						<div class="flex items-center">
							<span class="text-orange-500 mr-2">🐙</span>
							<span class="text-gray-700">Git</span>
						</div>
						<div class="flex items-center">
							<span class="text-blue-500 mr-2">🐳</span>
							<span class="text-gray-700">Docker</span>
						</div>
						<div class="flex items-center">
							<span class="text-purple-500 mr-2">📱</span>
							<span class="text-gray-700">Figma</span>
						</div>
						<div class="flex items-center">
							<span class="text-gray-500 mr-2">☁️</span>
							<span class="text-gray-700">AWS/Vercel</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Process -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
					Nuestro Proceso
				</h2>
				<p class="text-xl text-gray-600">
					Metodología probada para garantizar el éxito de tu proyecto
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
				<div class="text-center">
					<div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl font-bold text-blue-600">1</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Descubrimiento</h3>
					<p class="text-gray-600">Analizamos tus necesidades y definimos los objetivos del proyecto.</p>
				</div>

				<div class="text-center">
					<div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl font-bold text-green-600">2</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Diseño</h3>
					<p class="text-gray-600">Creamos wireframes y prototipos para validar la experiencia de usuario.</p>
				</div>

				<div class="text-center">
					<div class="bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl font-bold text-purple-600">3</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Desarrollo</h3>
					<p class="text-gray-600">Implementamos la solución usando las mejores prácticas y tecnologías.</p>
				</div>

				<div class="text-center">
					<div class="bg-orange-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl font-bold text-orange-600">4</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Lanzamiento</h3>
					<p class="text-gray-600">Desplegamos tu proyecto y ofrecemos soporte continuo.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section class="py-20 bg-gray-50">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
					Preguntas Frecuentes
				</h2>
				<p class="text-xl text-gray-600">
					Respuestas a las dudas más comunes sobre nuestros servicios
				</p>
			</div>

			<div class="space-y-8">
				<div class="bg-white rounded-lg p-8 shadow-lg">
					<h3 class="text-xl font-semibold text-gray-900 mb-3">¿Cuánto tiempo toma desarrollar un sitio web?</h3>
					<p class="text-gray-600">El tiempo varía según la complejidad. Un sitio web básico toma 2-4 semanas, mientras que un e-commerce puede tomar 6-12 semanas.</p>
				</div>

				<div class="bg-white rounded-lg p-8 shadow-lg">
					<h3 class="text-xl font-semibold text-gray-900 mb-3">¿Ofrecen servicios de mantenimiento?</h3>
					<p class="text-gray-600">Sí, ofrecemos planes de mantenimiento mensuales que incluyen actualizaciones, copias de seguridad y soporte técnico.</p>
				</div>

				<div class="bg-white rounded-lg p-8 shadow-lg">
					<h3 class="text-xl font-semibold text-gray-900 mb-3">¿Trabajan con clientes internacionales?</h3>
					<p class="text-gray-600">Absolutamente. Trabajamos con clientes de todo el mundo y nos adaptamos a diferentes zonas horarias para facilitar la comunicación.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="py-20 bg-gradient-to-r from-blue-600 to-purple-600">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
				¿Listo Para Comenzar?
			</h2>
			<p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
				Cuéntanos sobre tu proyecto y te enviaremos una propuesta personalizada
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="/cotiza" class="bg-white text-blue-600 hover:bg-blue-50 px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300 hover:scale-105">
					Solicitar Cotización 💰
				</a>
				<a href="/proyectos" class="border-2 border-white text-white hover:bg-white hover:text-blue-600 px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300">
					Ver Proyectos 📁
				</a>
			</div>
		</div>
	</section>

	<Footer />
</Layout>