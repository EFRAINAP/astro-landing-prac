---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";


// 🍞 Obtener breadcrumbs automáticamente
const currentPath = Astro.url.pathname;
const breadcrumbs = [{ name: "Inicio", href: "/" }];
---

<Layout title="Blog - Mi Landing" description="Artículos, noticias y tutoriales sobre desarrollo web">
  <Header currentPage="blog" />
  
  <main class="max-w-6xl mx-auto px-4 py-16">
    <!-- Breadcrumbs -->
    <nav class="mb-8" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 text-sm text-gray-500">
        {breadcrumbs.map((crumb, index) => (
          <li class="flex items-center">
            {index > 0 && <span class="mx-2">/</span>}
            <a 
              href={crumb.href}
              class={`hover:text-blue-600 ${index === breadcrumbs.length - 1 ? 'text-gray-900 font-medium' : 'text-gray-500'}`}
            >
              {crumb.name}
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <!-- Header de la página -->
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
        📝 Nuestro Blog
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Artículos sobre desarrollo web, diseño y tecnologías modernas
      </p>
    </div>

    <!-- Posts del blog -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Post 1 - Navegación desde ruta profunda -->
      <article class="bg-white rounded-lg shadow-lg overflow-hidden">
        <div class="p-6">
          <div class="mb-4">
            <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded">Categoría</span>
          </div>
          <h2 class="text-xl font-bold text-gray-900 mb-3">
            <a href="/blog/categoria/mi-primer-post" class="hover:text-blue-600">
              Mi Primer Post (Ruta Profunda)
            </a>
          </h2>
          <p class="text-gray-600 mb-4">
            Este post demuestra cómo la navegación funciona perfectamente desde rutas anidadas.
          </p>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">5 marzo, 2026</span>
            <a href="/blog/categoria/mi-primer-post" class="text-blue-600 hover:text-blue-800 font-medium">
              Leer más →
            </a>
          </div>
        </div>
      </article>

      <!-- Post 2 -->
      <article class="bg-white rounded-lg shadow-lg overflow-hidden">
        <div class="p-6">
          <div class="mb-4">
            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Tutorial</span>
          </div>
          <h2 class="text-xl font-bold text-gray-900 mb-3">
            Cómo crear rutas en Astro
          </h2>
          <p class="text-gray-600 mb-4">
            Aprende el sistema de routing file-based de Astro y por qué es tan potente.
          </p>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">4 marzo, 2026</span>
            <a href="#" class="text-blue-600 hover:text-blue-800 font-medium">
              Leer más →
            </a>
          </div>
        </div>
      </article>

      <!-- Post 3 -->
      <article class="bg-white rounded-lg shadow-lg overflow-hidden">
        <div class="p-6">
          <div class="mb-4">
            <span class="bg-purple-100 text-purple-800 text-xs font-medium px-2.5 py-0.5 rounded">Diseño</span>
          </div>
          <h2 class="text-xl font-bold text-gray-900 mb-3">
            Sistema de navegación centralizado
          </h2>
          <p class="text-gray-600 mb-4">
            Cómo mantener toda la navegación en un solo archivo para facilitar el mantenimiento.
          </p>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">3 marzo, 2026</span>
            <a href="#" class="text-blue-600 hover:text-blue-800 font-medium">
              Leer más →
            </a>
          </div>
        </div>
      </article>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <div class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-2xl p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">
          ¿Te gusta nuestro contenido?
        </h3>
        <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
          Suscríbete para recibir los últimos artículos y tutoriales directamente en tu correo.
        </p>
        <a 
          href="/cotiza"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-medium transition-colors duration-200"
        >
          Trabajemos juntos
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>