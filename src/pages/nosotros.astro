---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
---

<Layout title="Nosotros - Mi Landing" description="Conoce nuestro equipo de expertos en desarrollo web y tecnologías modernas">
	<Header currentPage="nosotros" />
	
	<!-- Hero Section -->
	<section class="bg-gradient-to-br from-blue-50 via-white to-purple-50 pt-20 pb-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
					Conoce Nuestro 
					<span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
						Equipo
					</span>
				</h1>
				<p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
					Somos un equipo apasionado de desarrolladores y diseñadores que transforman ideas en experiencias digitales excepcionales
				</p>
			</div>
		</div>
	</section>

	<!-- Our Story -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
						Nuestra Historia
					</h2>
					<div class="space-y-6 text-gray-600">
						<p class="text-lg">
							Comenzamos en 2020 con una misión simple: crear soluciones digitales que realmente 
							marquen la diferencia para nuestros clientes. Desde entonces, hemos ayudado a más 
							de 50 empresas a establecer su presencia digital.
						</p>
						<p>
							Nuestro enfoque se centra en combinar tecnologías de vanguardia con diseño centrado 
							en el usuario, garantizando que cada proyecto no solo se vea increíble, sino que 
							también funcione de manera excepcional.
						</p>
						<p>
							Creemos en la importancia de mantenernos actualizados con las últimas tendencias 
							y tecnologías, por eso trabajamos con frameworks modernos como Astro, React, 
							Svelte y Node.js.
						</p>
					</div>
				</div>
				
				<div class="relative">
					<div class="bg-gradient-to-br from-blue-100 to-purple-100 rounded-2xl p-8">
						<div class="grid grid-cols-2 gap-6">
							<div class="text-center">
								<div class="text-4xl font-bold text-blue-600 mb-2">50+</div>
								<div class="text-gray-600">Proyectos Completados</div>
							</div>
							<div class="text-center">
								<div class="text-4xl font-bold text-purple-600 mb-2">3+</div>
								<div class="text-gray-600">Años de Experiencia</div>
							</div>
							<div class="text-center">
								<div class="text-4xl font-bold text-green-600 mb-2">98%</div>
								<div class="text-gray-600">Clientes Satisfechos</div>
							</div>
							<div class="text-center">
								<div class="text-4xl font-bold text-orange-600 mb-2">24/7</div>
								<div class="text-gray-600">Soporte Técnico</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Team Members -->
	<section class="py-20 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
					Nuestro Equipo
				</h2>
				<p class="text-xl text-gray-600">
					Profesionales dedicados que hacen que tu proyecto sea extraordinario
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				<!-- Team Member 1 -->
				<div class="bg-white rounded-lg shadow-lg p-8 text-center hover:shadow-xl transition-shadow duration-300">
					<div class="w-24 h-24 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full mx-auto mb-6 flex items-center justify-center">
						<span class="text-3xl text-white font-bold">AM</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Ana Martínez</h3>
					<p class="text-blue-600 font-medium mb-4">CEO & Founder</p>
					<p class="text-gray-600 mb-6">
						Visionaria con 10+ años en desarrollo web. Especialista en arquitecturas escalables y liderazgo de equipos.
					</p>
					<div class="flex justify-center space-x-4">
						<a href="#" class="text-blue-600 hover:text-blue-800">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd"></path>
							</svg>
						</a>
						<a href="#" class="text-gray-400 hover:text-blue-600">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				</div>

				<!-- Team Member 2 -->
				<div class="bg-white rounded-lg shadow-lg p-8 text-center hover:shadow-xl transition-shadow duration-300">
					<div class="w-24 h-24 bg-gradient-to-br from-green-400 to-green-600 rounded-full mx-auto mb-6 flex items-center justify-center">
						<span class="text-3xl text-white font-bold">CL</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Carlos López</h3>
					<p class="text-green-600 font-medium mb-4">Lead Developer</p>
					<p class="text-gray-600 mb-6">
						Experto en JavaScript moderno, React, Svelte y Node.js. Apasionado por el code review y las mejores prácticas.
					</p>
					<div class="flex justify-center space-x-4">
						<a href="#" class="text-blue-600 hover:text-blue-800">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd"></path>
							</svg>
						</a>
						<a href="#" class="text-gray-400 hover:text-blue-600">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				</div>

				<!-- Team Member 3 -->
				<div class="bg-white rounded-lg shadow-lg p-8 text-center hover:shadow-xl transition-shadow duration-300">
					<div class="w-24 h-24 bg-gradient-to-br from-purple-400 to-purple-600 rounded-full mx-auto mb-6 flex items-center justify-center">
						<span class="text-3xl text-white font-bold">LR</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Laura Rodríguez</h3>
					<p class="text-purple-600 font-medium mb-4">UX/UI Designer</p>
					<p class="text-gray-600 mb-6">
						Diseñadora con enfoque en experiencia de usuario. Especialista en interfaces intuitivas y accesibles.
					</p>
					<div class="flex justify-center space-x-4">
						<a href="#" class="text-blue-600 hover:text-blue-800">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd"></path>
							</svg>
						</a>
						<a href="#" class="text-gray-400 hover:text-purple-600">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
								<path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Values -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
					Nuestros Valores
				</h2>
				<p class="text-xl text-gray-600">
					Los principios que guían cada decisión y proyecto que emprendemos
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
				<div class="text-center">
					<div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
						<svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Innovación</h3>
					<p class="text-gray-600">Siempre buscamos las mejores soluciones tecnológicas para cada proyecto.</p>
				</div>

				<div class="text-center">
					<div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
						<svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Calidad</h3>
					<p class="text-gray-600">Nos comprometemos con la excelencia en cada línea de código.</p>
				</div>

				<div class="text-center">
					<div class="bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Colaboración</h3>
					<p class="text-gray-600">Trabajamos como socios, no como proveedores.</p>
				</div>

				<div class="text-center">
					<div class="bg-orange-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
						<svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Puntualidad</h3>
					<p class="text-gray-600">Cumplimos con los plazos acordados sin comprometer la calidad.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="py-20 bg-gradient-to-r from-blue-600 to-purple-600">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
				¿Trabajamos Juntos?
			</h2>
			<p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
				Nos encantaría conocer tu proyecto y ayudarte a llevarlo al siguiente nivel
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="/cotiza" class="bg-white text-blue-600 hover:bg-blue-50 px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300 hover:scale-105">
					Iniciar Proyecto 🚀
				</a>
				<a href="/proyectos" class="border-2 border-white text-white hover:bg-white hover:text-blue-600 px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300">
					Ver Nuestro Trabajo 📁
				</a>
			</div>
		</div>
	</section>

	<Footer />
</Layout>