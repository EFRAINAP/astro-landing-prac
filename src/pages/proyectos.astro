---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

// Project data - in a real app, this would come from a database or CMS
const projects = [
  {
    id: 1,
    title: "E-commerce Fashion Store",
    category: "E-commerce",
    tech: ["React", "Node.js", "Stripe", "MongoDB"],
    image: "💼",
    description: "Tienda online completa para marca de ropa con sistema de inventory y pagos",
    features: ["Catálogo de productos", "Carrito de compras", "Pagos online", "Panel de administración"]
  },
  {
    id: 2,
    title: "Restaurant Booking App",
    category: "Web App",
    tech: ["Astro", "Svelte", "Firebase"],
    image: "🍽️",
    description: "Sistema de reservas para restaurante con gestión de mesas y notificaciones",
    features: ["Reservas online", "Gestión de mesas", "Notificaciones SMS", "Dashboard analytics"]
  },
  {
    id: 3,
    title: "Fitness Tracker Mobile",
    category: "Mobile App",
    tech: ["React Native", "Redux", "Node.js"],
    image: "🏋️",
    description: "App móvil para tracking de ejercicios con planes personalizados",
    features: ["Tracking workouts", "Planes personalizados", "Social features", "Analytics"]
  },
  {
    id: 4,
    title: "Corporate Website",
    category: "Website",
    tech: ["Astro", "Tailwind", "Netlify"],
    image: "🏢",
    description: "Sitio corporativo moderno con blog y formularios de contacto",
    features: ["Diseño responsive", "Blog CMS", "SEO optimized", "Contact forms"]
  },
  {
    id: 5,
    title: "Learning Management System",
    category: "Web App",
    tech: ["Vue.js", "Laravel", "MySQL"],
    image: "📚",
    description: "Plataforma educativa con cursos, quizzes y certificaciones",
    features: ["Gestión de cursos", "Video streaming", "Certificaciones", "Progress tracking"]
  },
  {
    id: 6,
    title: "Real Estate Platform",
    category: "Web App",
    tech: ["Next.js", "PostgreSQL", "Mapbox"],
    image: "🏠",
    description: "Plataforma inmobiliaria con búsqueda avanzada y mapas interactivos",
    features: ["Búsqueda avanzada", "Mapas interactivos", "Tours virtuales", "Lead management"]
  }
];

const categories = ["Todos", "Website", "E-commerce", "Web App", "Mobile App"];
const techStack = ["Astro", "React", "Svelte", "Vue.js", "Node.js", "Next.js"];
---

<Layout title="Proyectos - Mi Landing" description="Descubre nuestro portafolio de proyectos web y aplicaciones móviles exitosos">
	<Header currentPage="proyectos" />
	
	<!-- Hero Section -->
	<section class="bg-gradient-to-br from-blue-50 via-white to-purple-50 pt-20 pb-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
					Nuestros
					<span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
						Proyectos
					</span>
				</h1>
				<p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
					Explora nuestro portafolio de soluciones digitales exitosas que han transformado negocios
				</p>
			</div>
		</div>
	</section>

	<!-- Filters -->
	<section class="py-16 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<!-- Category Filters -->
			<div class="text-center mb-12">
				<h2 class="text-2xl font-bold text-gray-900 mb-6">Filtrar por Categoría</h2>
				<div id="category-filters" class="flex flex-wrap justify-center gap-4">
					{categories.map(category => (
						<button 
							class="category-btn px-6 py-3 rounded-lg font-medium transition-all duration-300 ${category === 'Todos' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}"
							data-category={category}
						>
							{category}
						</button>
					))}
				</div>
			</div>

			<!-- Projects Grid -->
			<div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{projects.map(project => (
					<div class="project-card bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 hover:scale-105" data-category={project.category}>
						<!-- Project Image/Icon -->
						<div class="bg-gradient-to-br from-blue-100 to-purple-100 h-48 flex items-center justify-center">
							<span class="text-6xl">{project.image}</span>
						</div>
						
						<!-- Project Content -->
						<div class="p-6">
							<div class="flex items-center justify-between mb-3">
								<span class="bg-blue-100 text-blue-800 text-xs font-semibold px-3 py-1 rounded-full">
									{project.category}
								</span>
							</div>
							
							<h3 class="text-xl font-bold text-gray-900 mb-3">{project.title}</h3>
							<p class="text-gray-600 mb-4">{project.description}</p>
							
							<!-- Tech Stack -->
							<div class="mb-4">
								<div class="flex flex-wrap gap-2">
									{project.tech.map(tech => (
										<span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded">
											{tech}
										</span>
									))}
								</div>
							</div>
							
							<!-- Features -->
							<div class="mb-6">
								<h4 class="text-sm font-semibold text-gray-900 mb-2">Características:</h4>
								<ul class="text-sm text-gray-600 space-y-1">
									{project.features.map(feature => (
										<li class="flex items-center">
											<svg class="w-3 h-3 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
											</svg>
											{feature}
										</li>
									))}
								</ul>
							</div>
							
							<!-- CTA Button -->
							<button class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-semibold transition-colors project-details-btn" data-project={JSON.stringify(project)}>
								Ver Detalles
							</button>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Tech Stack Used -->
	<section class="py-20 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">Tecnologías Utilizadas</h2>
				<p class="text-xl text-gray-600">Stack tecnológico que usamos en nuestros proyectos</p>
			</div>
			
			<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8">
				{techStack.map(tech => (
					<div class="bg-white rounded-lg p-6 text-center shadow-md hover:shadow-lg transition-shadow">
						<h3 class="font-semibold text-gray-900">{tech}</h3>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Project Stats -->
	<section class="py-20 bg-blue-600">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center text-white">
				<h2 class="text-3xl font-bold mb-12">Nuestros Números</h2>
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
					<div>
						<div class="text-4xl font-bold mb-2">50+</div>
						<div class="text-blue-200">Proyectos Completados</div>
					</div>
					<div>
						<div class="text-4xl font-bold mb-2">98%</div>
						<div class="text-blue-200">Satisfacción del Cliente</div>
					</div>
					<div>
						<div class="text-4xl font-bold mb-2">3+</div>
						<div class="text-blue-200">Años de Experiencia</div>
					</div>
					<div>
						<div class="text-4xl font-bold mb-2">24/7</div>
						<div class="text-blue-200">Soporte Técnico</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
				¿Te Gustó Algún Proyecto?
			</h2>
			<p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
				Podemos crear algo similar o mejor para tu negocio
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="/cotiza" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300 hover:scale-105">
					Solicitar Cotización 💰
				</a>
				<a href="/nosotros" class="border-2 border-blue-600 text-blue-600 hover:bg-blue-600 hover:text-white px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300">
					Conocer Nuestro Equipo 👥
				</a>
			</div>
		</div>
	</section>

	<!-- Project Details Modal -->
	<div id="project-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
		<div class="bg-white rounded-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
			<div class="p-8">
				<div class="flex justify-between items-start mb-6">
					<h3 id="modal-title" class="text-2xl font-bold text-gray-900"></h3>
					<button id="close-modal" class="text-gray-400 hover:text-gray-600">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>
				
				<div id="modal-content" class="space-y-6">
					<!-- Content will be populated by JavaScript -->
				</div>
				
				<div class="mt-8 flex gap-4">
					<a href="/cotiza" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition-colors">
						Proyecto Similar
					</a>
					<button id="close-modal-btn" class="border border-gray-300 text-gray-700 hover:bg-gray-50 px-6 py-3 rounded-lg font-semibold transition-colors">
						Cerrar
					</button>
				</div>
			</div>
		</div>
	</div>

	<Footer />

	<script>
		// Filter functionality
		document.addEventListener('DOMContentLoaded', function() {
			const categoryButtons = document.querySelectorAll('.category-btn');
			const projectCards = document.querySelectorAll('.project-card');
			const modal = document.getElementById('project-modal');
			const modalTitle = document.getElementById('modal-title');
			const modalContent = document.getElementById('modal-content');
			const closeModalBtns = document.querySelectorAll('#close-modal, #close-modal-btn');
			
			// Category filtering
			const categoryButtonsTyped = document.querySelectorAll<HTMLButtonElement>('.category-btn');
			categoryButtonsTyped.forEach((button) => {
				button.addEventListener('click', function() {
					const category = button.dataset.category;
					
					// Update button styles
					categoryButtonsTyped.forEach((btn) => {
						btn.classList.remove('bg-blue-600', 'text-white');
						btn.classList.add('bg-gray-100', 'text-gray-700');
					});
					button.classList.remove('bg-gray-100', 'text-gray-700');
					button.classList.add('bg-blue-600', 'text-white');
					
					// Filter projects
					const projectCardsTyped = document.querySelectorAll<HTMLElement>('.project-card');
					projectCardsTyped.forEach((card) => {
						if (category === 'Todos' || card.dataset.category === category) {
							card.style.display = 'block';
							setTimeout(() => { card.style.opacity = '1'; }, 50);
						} else {
							card.style.opacity = '0';
							setTimeout(() => { card.style.display = 'none'; }, 300);
						}
					});
				});
			});
			
			// Project details modal
			const detailButtons = document.querySelectorAll<HTMLButtonElement>('.project-details-btn');
			detailButtons.forEach((button) => {
				button.addEventListener('click', function() {
					if (!button.dataset.project) return;
					const project = JSON.parse(button.dataset.project);
					
					if (modalTitle) modalTitle.textContent = project.title;
					if (modalContent) {
						modalContent.innerHTML = `
						<div class="text-center">
							<div class="text-6xl mb-4">${project.image}</div>
							<span class="bg-blue-100 text-blue-800 text-sm font-semibold px-3 py-1 rounded-full">
								${project.category}
							</span>
						</div>
						
						<div>
							<h4 class="font-semibold text-gray-900 mb-2">Descripción</h4>
							<p class="text-gray-600">${project.description}</p>
						</div>
						
						<div>
							<h4 class="font-semibold text-gray-900 mb-2">Tecnologías</h4>
							<div class="flex flex-wrap gap-2">
								${project.tech.map((tech: string) => `<span class="bg-gray-100 text-gray-700 text-sm px-3 py-1 rounded">${tech}</span>`).join('')}
							</div>
						</div>
						
						<div>
							<h4 class="font-semibold text-gray-900 mb-2">Características</h4>
							<ul class="text-gray-600 space-y-2">
								${project.features.map((feature: string) => `
									<li class="flex items-center">
										<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
											<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
										</svg>
										${feature}
									</li>
								`).join('')}
							</ul>
						</div>
					`;
					}
					
					if (modal) {
						modal.classList.remove('hidden');
						document.body.style.overflow = 'hidden';
					}
				});
			});
			
			// Close modal
			const closeButtons = document.querySelectorAll<HTMLButtonElement>('#close-modal, #close-modal-btn');
			closeButtons.forEach((btn) => {
				btn.addEventListener('click', function() {
					if (modal) {
						modal.classList.add('hidden');
						document.body.style.overflow = 'auto';
					}
				});
			});
			
			// Close modal on backdrop click
			if (modal) {
				modal.addEventListener('click', function(e: MouseEvent) {
					if (e.target === modal && modal) {
						modal.classList.add('hidden');
						document.body.style.overflow = 'auto';
					}
				});
			}
		});
	</script>
</Layout>