---
// Datos de servicios que se pueden pasar como props o usar por defecto
const services = [
  {
    iconSvg: `<svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
    iconColor: "text-blue-600",
    title: "Desarrollo Web",
    description: "Sitios web modernos, rápidos y optimizados para SEO con las últimas tecnologías.",
    features: ["Astro, React, Svelte", "Responsive Design", "SEO Optimizado"]
  },
  {
    iconSvg: `<svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>`,
    iconColor: "text-green-600", 
    title: "E-commerce",
    description: "Tiendas online completas con sistemas de pago y gestión de inventario.",
    features: ["Shopify, WooCommerce", "Pagos en línea", "Panel de administrador"]
  },
  {
    iconSvg: `<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a1 1 0 001-1v-4.5c0-.83-.67-1.5-1.5-1.5h-8c-.83 0-1.5.67-1.5 1.5V20a1 1 0 001 1zM10 9V6a2 2 0 012-2h0a2 2 0 012 2v3M9 9h6l1 5H8l1-5z" /></svg>`,
    iconColor: "text-purple-600",
    title: "Apps Móviles", 
    description: "Aplicaciones nativas y PWAs para iOS y Android con excelente UX.",
    features: ["React Native, Flutter", "PWAs", "App Store deployment"]
  }
];
---

<!-- Services Preview -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Nuestros Servicios
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Ofrecemos soluciones completas para llevar tu negocio al siguiente nivel digital
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow duration-300 border border-gray-100">
          <div class="mb-4" set:html={service.iconSvg}></div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">{service.title}</h3>
          <p class="text-gray-600 mb-4">{service.description}</p>
          <ul class="text-sm text-gray-500 space-y-1">
            {service.features.map((feature) => (
              <li class="flex items-center gap-2">
                <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="text-center mt-12">
      <a 
        href="/servicios" 
        class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition-colors"
      >
        Ver Todos los Servicios →
      </a>
    </div>
  </div>
</section>